{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/system-zow.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/system-zow",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/correspondencia",
      "destination": "/correspondencia.html"
    },
    {
      "source": "/panel",
      "destination": "/correspondencia.html"
    },
    {
      "source": "/consulta",
      "destination": "/consulta.html"
    },
    {
      "source": "/consulta/:slug",
      "destination": "/consulta.html"
    },
    {
      "source": "/ventas-almacen",
      "destination": "/ventas-almacen.html"
    },
    {
      "source": "/ventas",
      "destination": "/ventas-almacen.html"
    }
  ]
}
