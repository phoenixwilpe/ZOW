{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/system-zow.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/system-zow",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/correspondencia",
      "destination": "/correspondencia.html"
    },
    {
      "source": "/panel",
      "destination": "/correspondencia.html"
    },
    {
      "source": "/consulta",
      "destination": "/consulta.html"
    },
    {
      "source": "/consulta/:slug",
      "destination": "/consulta.html"
    },
    {
      "source": "/ventas-almacen",
      "destination": "/ventas-almacen.html"
    },
    {
      "source": "/ventas",
      "destination": "/ventas-almacen.html"
    }
  ]
}
