{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/correspondencia",
      "destination": "/index.html"
    },
    {
      "source": "/panel",
      "destination": "/index.html"
    },
    {
      "source": "/consulta",
      "destination": "/consulta.html"
    },
    {
      "source": "/consulta/:slug",
      "destination": "/consulta.html"
    }
  ]
}
